{
  "multipart": [
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_core"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm"
      },
      "when": {
        "north": "connected"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm",
        "y": 90
      },
      "when": {
        "east": "connected"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm",
        "y": 180
      },
      "when": {
        "south": "connected"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm",
        "y": 270
      },
      "when": {
        "west": "connected"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm",
        "x": 270
      },
      "when": {
        "up": "connected"
      }
    },
    {
      "apply": {
        "model": "excessive_utilities:block/rationing_pipe_arm",
        "x": 90
      },
      "when": {
        "down": "connected"
      }
    }
  ]
}